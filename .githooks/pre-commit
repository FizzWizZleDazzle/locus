#!/bin/bash
# Pre-commit hook to prevent hardcoded production URLs and sensitive information

# ANSI color codes
RED='\033[0;31m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo -e "${BLUE}Running pre-commit checks...${NC}"
echo ""

# Ensure gitleaks is in PATH
export PATH="$HOME/.local/bin:$PATH"

# Auto-install gitleaks if not found
if ! command -v gitleaks &> /dev/null; then
    echo -e "${YELLOW}Gitleaks not found. Installing...${NC}"

    GITLEAKS_VERSION="8.21.2"
    GITLEAKS_URL="https://github.com/gitleaks/gitleaks/releases/download/v${GITLEAKS_VERSION}/gitleaks_${GITLEAKS_VERSION}_linux_x64.tar.gz"

    # Create bin directory if it doesn't exist
    mkdir -p ~/.local/bin

    # Download and install gitleaks
    if curl -sSL "$GITLEAKS_URL" | tar -xz -C ~/.local/bin gitleaks 2>&1; then
        echo -e "${GREEN}Gitleaks ${GITLEAKS_VERSION} installed successfully to ~/.local/bin/${NC}"
        GITLEAKS_AVAILABLE=true
    else
        echo -e "${RED}Failed to install gitleaks${NC}"
        echo -e "${YELLOW}Skipping secret detection...${NC}"
        echo ""
        GITLEAKS_AVAILABLE=false
    fi
else
    GITLEAKS_AVAILABLE=true
fi

FOUND_ISSUES=0

# =============================================================================
# 1. Check for hardcoded production URLs (project-specific)
# =============================================================================
echo -e "${BLUE}Checking for hardcoded production URLs...${NC}"

FORBIDDEN_PATTERNS=(
    'https://api\.locusmath\.org'
    'https://locusmath\.org'
)

for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
    # Search staged .rs files (excluding env.rs, build.rs, and comments)
    MATCHES=$(git diff --cached --name-only --diff-filter=ACM | \
        grep '\.rs$' | \
        grep -v 'env\.rs$' | \
        grep -v 'build\.rs$' | \
        xargs -I {} sh -c "grep -n '$pattern' {} 2>/dev/null | grep -v '^\s*//' || true")

    if [ -n "$MATCHES" ]; then
        FOUND_ISSUES=1
        echo -e "${RED}ERROR: Found hardcoded production URL pattern: $pattern${NC}"
        echo "$MATCHES"
        echo ""
    fi
done

if [ $FOUND_ISSUES -eq 0 ]; then
    echo -e "${GREEN}[PASS] No hardcoded production URLs found${NC}"
fi

echo ""

# =============================================================================
# 2. Run gitleaks for comprehensive secret detection
# =============================================================================
if [ "$GITLEAKS_AVAILABLE" = true ]; then
    echo -e "${BLUE}Running gitleaks secret detection...${NC}"

    # Run gitleaks on staged files only
    # --staged: only scan staged changes
    # --no-banner: cleaner output
    # --verbose: show what it's checking
    if ! gitleaks protect --staged --no-banner --redact 2>&1; then
        FOUND_ISSUES=1
        echo ""
        echo -e "${RED}Gitleaks detected potential secrets in your staged changes!${NC}"
    else
        echo -e "${GREEN}[PASS] No secrets detected by gitleaks${NC}"
    fi
    echo ""
fi

# =============================================================================
# Final result
# =============================================================================
if [ $FOUND_ISSUES -eq 1 ]; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}COMMIT BLOCKED: Security issues detected${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${YELLOW}Environment Configuration Rules:${NC}"
    echo ""
    echo "  WRONG: format!(\"https://api.locusmath.org/api/auth/{}\", path)"
    echo "  RIGHT: format!(\"{}/auth/{}\", crate::env::api_base(), path)"
    echo ""
    echo "  Frontend API calls should use:"
    echo "    - crate::env::api_base()       for API URLs"
    echo "    - crate::env::frontend_base()  for frontend URLs"
    echo ""
    echo -e "${YELLOW}Security Guidelines:${NC}"
    echo ""
    echo "  - Never commit passwords, API keys, tokens, or secrets"
    echo "  - Use .env files for local development (already gitignored)"
    echo "  - Use environment variables in production"
    echo "  - Review gitleaks output above for specific issues"
    echo ""
    echo "  See CONTRIBUTING.md for full guidelines."
    echo ""
    exit 1
fi

echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}All security checks passed!${NC}"
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
exit 0
