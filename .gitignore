# Generated by Cargo
debug
target

# Build artifacts
**/dist/

# These are backup files generated by rustfmt
**/*.rs.bk

*.bak

*.pdf

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
.idea/

# Environment files
.env

# Local helm overrides (contain secrets — never commit)
helm/**/values.local.yaml
helm/**/values.secret.yaml

# Frontend build output
crates/frontend/dist/

# Python
__pycache__/
*.pyc
.venv/
venv/

# Generated SQL files
content-gen/*.sql

# Exports (dsl-cli output, import SQL, SQLite dumps)
exports/

# Generated JSONL dumps
*.jsonl

# Editor
.vscode/
*.swp
*.swo

# .env.production no longer used — all values in .env with PRODUCTION_ prefix

*.log

kubeconfig

# Downloaded problem databases
.devcontainer/*.db

.claude/

# Vendored Typst packages (cetz, oxifmt) — fetched by
# scripts/fetch-diagram-assets.sh from packages.typst.org with pinned
# SHA-256. Only LICENSE files are committed (for compliance visibility).
crates/dsl/assets/*/src/
crates/dsl/assets/*/cetz-core/
crates/dsl/assets/*/typst.toml
crates/dsl/assets/*/README.md
crates/dsl/assets/*/.fetched-*
crates/dsl/assets/*/lib.typ
crates/dsl/assets/*/oxifmt.typ
