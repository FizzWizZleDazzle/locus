# Production Environment Variables Template
# Copy this to .env.production and fill in real values
# NEVER commit .env.production to git!

# ============================================
# CRITICAL: Generate secure secrets first!
# ============================================
# Run these commands to generate secure random secrets:
#   JWT_SECRET: openssl rand -base64 32
#   DB_PASSWORD: openssl rand -base64 32

# Environment
ENVIRONMENT=production

# Database
DATABASE_URL=postgresql://locus:YOUR_SECURE_DB_PASSWORD@localhost:5432/locus
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD

# Security Secrets (32+ characters required)
JWT_SECRET=GENERATE_WITH_OPENSSL_RAND_BASE64_32

# CORS & Frontend URLs
ALLOWED_ORIGINS=https://yourdomain.com
FRONTEND_BASE_URL=https://yourdomain.com
OAUTH_REDIRECT_BASE=https://api.yourdomain.com

# OAuth (Google)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# OAuth (GitHub)
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Email Service (optional - email verification not in MVP)
RESEND_API_KEY=your_resend_api_key_if_needed
RESEND_FROM_EMAIL=no-reply@yourdomain.com
RESEND_FROM_NAME=Locus

# Server Config
HOST=0.0.0.0
PORT=3000
JWT_EXPIRY_HOURS=24
