# ── Database ──
DATABASE_URL=postgres://locus:locus_dev_password@localhost:5433/locus

# ── Main Backend ──
HOST=0.0.0.0
PORT=3000
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:8080
# CRITICAL: In production, generate a secure secret with: openssl rand -base64 32
JWT_SECRET=development-secret-change-in-production
JWT_EXPIRY_HOURS=24

# ── OAuth (optional - leave empty/unset to disable a provider) ──
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Base URL for OAuth redirect callbacks (must match what's configured in provider)
OAUTH_REDIRECT_BASE=http://localhost:3000

# ── Email (Resend) ──
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=no-reply@locusmath.org
RESEND_FROM_NAME=Locus
FRONTEND_BASE_URL=http://localhost:8080

# ── Rate Limiting (optional, defaults shown) ──
RATE_LIMIT_AUTH_PER_15MIN=5
RATE_LIMIT_LOGIN_PER_15MIN=10
RATE_LIMIT_GENERAL_PER_MIN=1000

# ── Cookie Domain (for shared auth across subdomains, e.g. locusmath.org) ──
COOKIE_DOMAIN=

# ── Community Services Backend ──
HEALTH_CHECK_URL=http://localhost:3000/api/health
HEALTH_CHECK_INTERVAL_SECS=300

# ── Production (used by deploy scripts only) ──
# Generate secrets: openssl rand -base64 32
PRODUCTION_DATABASE_URL=postgresql://locus:YOUR_SECURE_DB_PASSWORD@localhost:5432/locus
PRODUCTION_DB_PASSWORD=YOUR_SECURE_DB_PASSWORD
PRODUCTION_JWT_SECRET=GENERATE_WITH_OPENSSL_RAND_BASE64_32
PRODUCTION_ALLOWED_ORIGINS=https://yourdomain.com
PRODUCTION_FRONTEND_BASE_URL=https://yourdomain.com
PRODUCTION_OAUTH_REDIRECT_BASE=https://api.yourdomain.com
PRODUCTION_RESEND_FROM_EMAIL=no-reply@yourdomain.com
PRODUCTION_CLOUDFLARED_TUNNEL=
PRODUCTION_COMMUNITY_ALLOWED_ORIGINS=https://forum.yourdomain.com,https://status.yourdomain.com
PRODUCTION_COMMUNITY_CLOUDFLARED_TOKEN=
