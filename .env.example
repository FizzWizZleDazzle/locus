# Database
DATABASE_URL=postgres://locus:locus_dev_password@localhost:5433/locus

# Server
HOST=0.0.0.0
PORT=3000

# Environment (development or production)
# Production mode enforces strong JWT secrets and security validations
ENVIRONMENT=development

# CORS - Comma-separated list of allowed origins
# In production, set this to your frontend domain(s)
ALLOWED_ORIGINS=http://localhost:8080

# JWT
# CRITICAL: In production, generate a secure secret with: openssl rand -base64 32
# Production requires 32+ character secrets
JWT_SECRET=development-secret-change-in-production
JWT_EXPIRY_HOURS=24

# Factory API Key (for content submission)
# CRITICAL: In production, generate a secure key with: openssl rand -base64 32
# Production requires 32+ character keys
# WARNING: Change this in production! This default is only for development.
API_KEY_SECRET=development-factory-key-change-in-production

# Rate Limiting (optional, defaults shown)
# Auth endpoints (register): requests per 15 minutes
RATE_LIMIT_AUTH_PER_15MIN=5
# Login endpoint: requests per 15 minutes
RATE_LIMIT_LOGIN_PER_15MIN=10
# General endpoints: requests per minute
RATE_LIMIT_GENERAL_PER_MIN=1000
